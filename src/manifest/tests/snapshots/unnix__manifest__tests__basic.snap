                        HydraResolver {
                            base: "https://hydra.nixos.org",
                            project: "nixpkgs",
                            jobset: "unstable",
                            job: "{package}.{system}",
                        },
                    ),
                },
            },
            env: {
                "LIBCLANG_PATH": "{libclang.lib}/lib",
            },
            caches: [
                Url {
                    scheme: "https",
                    cannot_be_a_base: false,
                    username: "",
                    password: None,
                    host: Some(
                        Domain(
                            "cache.nixos.org",
