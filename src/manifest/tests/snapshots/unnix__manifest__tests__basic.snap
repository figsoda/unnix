                            jobset: "unstable",
                            job: "{package}.{system}",
                        },
                    ),
                },
                "libclang": Package {
                    package: "libclang",
                    outputs: {
                        "lib",
                    },
                    resolver: Hydra(
                        HydraResolver {
                            base: "https://hydra.nixos.org",
                            project: "nixpkgs",
                            jobset: "unstable",
                            job: "{package}.{system}",
                        },
                    ),
                },
                "mercurial": Package {
                    package: "mercurial",
                    outputs: {},
                    resolver: Hydra(
                        HydraResolver {
                            base: "https://hydra.nixos.org",
                            project: "nixpkgs",
                            jobset: "unstable",
                            job: "{package}.{system}",
